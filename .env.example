# ========== 服务器 ==========
NODE_ENV=development
PORT=3000
HOST=0.0.0.0

# ========== MySQL ==========
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_password
MYSQL_DATABASE=miaozhanggui

# ========== Redis ==========
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# ========== JWT ==========
JWT_SECRET=change_this_to_a_random_secret_key_123456
JWT_EXPIRES_IN=2h
JWT_REFRESH_EXPIRES_IN=7d

# ========== 文件上传 ==========
UPLOAD_DIR=uploads
MAX_FILE_SIZE=5242880

# ========== CORS ==========
CORS_ORIGINS=http://localhost:8080,http://127.0.0.1:8080,http://localhost:5500,http://127.0.0.1:5500

# ========== 微信 ==========
WECHAT_APPID=
WECHAT_SECRET=
WECHAT_MCHID=
WECHAT_API_KEY=
